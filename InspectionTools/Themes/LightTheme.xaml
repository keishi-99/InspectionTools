<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  背景・文字色  -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFF7F9FC" />
    <SolidColorBrush x:Key="AppForegroundBrush" Color="#222" />

    <!--  Button  -->
    <Style TargetType="Button">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        Padding="2"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--  ホバー時  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#DDE3EB" />
                            <Setter Property="BorderBrush" Value="#A0A0A0" />
                        </Trigger>
                        <!--  押下時  -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#C8D1E0" />
                            <Setter Property="BorderBrush" Value="#808080" />
                        </Trigger>
                        <!--  無効時  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#F5F5F5" />
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter Property="BorderBrush" Value="#E0E0E0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  CheckBox  -->
    <Style TargetType="CheckBox">
        <Setter Property="Background" Value="#FFDDDDDD" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border
                        Padding="2"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--  ホバー時  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#DDE3EB" />
                            <Setter Property="BorderBrush" Value="#A0A0A0" />
                        </Trigger>
                        <!--  チェック時  -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background" Value="#BCDDEE" />
                            <Setter Property="BorderBrush" Value="#808080" />
                        </Trigger>
                        <!--  無効時  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#F5F5F5" />
                            <Setter Property="Foreground" Value="#999999" />
                            <Setter Property="BorderBrush" Value="#E0E0E0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  RadioButton  -->
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="Gray" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--  チェック時  -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="Black" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </Trigger>
                        <!--  無効時  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="Gray" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>