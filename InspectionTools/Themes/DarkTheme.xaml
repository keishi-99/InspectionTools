<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  背景・文字色  -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="AppForegroundBrush" Color="#FFFFFF" />

    <!--  Window 共通設定  -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
    </Style>

    <!--  Button  -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="#3A3A3A" />
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="#555" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--  ホバー時  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#4A4A4A" />
                            <Setter Property="BorderBrush" Value="#888" />
                        </Trigger>
                        <!--  押下時  -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#2F2F2F" />
                            <Setter Property="BorderBrush" Value="#666" />
                        </Trigger>
                        <!--  無効時  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#2A2A2A" />
                            <Setter Property="Foreground" Value="#777" />
                            <Setter Property="BorderBrush" Value="#333" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  CheckBox  -->
    <Style TargetType="CheckBox">
        <Setter Property="Background" Value="#3A3A3A" />
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="#555" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border
                        x:Name="border"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--  マウスホバー時  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#4A4A4A" />
                        </Trigger>
                        <!--  押下時  -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#2F2F2F" />
                        </Trigger>
                        <!--  チェックON時  -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#375A7F" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#4A90E2" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </Trigger>
                        <!--  無効時  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#2A2A2A" />
                            <Setter Property="Foreground" Value="#777" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  TextBlock  -->
    <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
    </Style>

