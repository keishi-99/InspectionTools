<Window
    x:Class="InspectionTools.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:InspectionTools.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InspectionTools"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Icon="/sine.ico"
    ResizeMode="CanMinimize"
    SizeToContent="WidthAndHeight"
    Style="{StaticResource MaterialDesignWindow}"
    mc:Ignorable="d">
    <Grid x:Name="MainGrid">

        <materialDesign:DrawerHost x:Name="MainWindowDrawer" IsLeftDrawerOpen="{Binding ElementName=MenuToggleButton, Path=IsChecked}">
            <materialDesign:DrawerHost.LeftDrawerContent>
                <DockPanel>
                    <ToggleButton
                        Margin="16"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Top"
                        IsChecked="{Binding ElementName=MenuToggleButton, Path=IsChecked, Mode=TwoWay}"
                        Style="{StaticResource MaterialDesignHamburgerToggleButton}" />

                    <StackPanel Margin="16,4">
                        <Button
                            x:Name="ProductListButton"
                            Margin="5"
                            Padding="5,2,5,2"
                            Click="ProductListButton_Click"
                            Content="製品選択"
                            Style="{StaticResource MaterialDesignFlatButton}" />
                        <Button
                            x:Name="InstListButton"
                            Margin="5"
                            Padding="5,2,5,2"
                            Click="InstListButton_Click"
                            Content="測定器設定"
                            Style="{StaticResource MaterialDesignFlatButton}" />
                    </StackPanel>
                </DockPanel>
            </materialDesign:DrawerHost.LeftDrawerContent>
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,*">

                <materialDesign:ColorZone Padding="5" Mode="PrimaryDark">
                    <UniformGrid Columns="3">

                        <ToggleButton
                            x:Name="MenuToggleButton"
                            HorizontalAlignment="Left"
                            AutomationProperties.Name="HamburgerToggleButton"
                            IsChecked="False"
                            Style="{DynamicResource MaterialDesignHamburgerToggleButton}" />

                        <TextBlock
                            x:Name="Time"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Meiryo"
                            FontSize="15"
                            FontWeight="Bold"
                            Language="ja-jp"
                            Text="00:00:00"
                            TextAlignment="Center" />

                        <materialDesign:PopupBox
                            HorizontalAlignment="Right"
                            PlacementMode="BottomAndAlignRightEdges"
                            StaysOpen="True">

                            <Grid
                                Margin="5"
                                ColumnDefinitions="*,Auto"
                                RowDefinitions="Auto,Auto,Auto">

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="ヘルプ" />
                                <ToggleButton
                                    x:Name="HelpCheckBox"
                                    Grid.Column="1"
                                    Margin="5"
                                    Checked="HelpCheckBox_Checked"
                                    Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                    Unchecked="HelpCheckBox_Unchecked">
                                    <ToggleButton.LayoutTransform>
                                        <ScaleTransform ScaleX="0.7" ScaleY="0.7" />
                                    </ToggleButton.LayoutTransform>
                                </ToggleButton>

                                <TextBlock
                                    Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Text="最前面" />
                                <ToggleButton
                                    x:Name="TopMostCheckBox"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="5"
                                    Checked="TopMostCheckBox_Checked"
                                    Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                    Unchecked="TopMostCheckBox_Unchecked">
                                    <ToggleButton.LayoutTransform>
                                        <ScaleTransform ScaleX="0.7" ScaleY="0.7" />
                                    </ToggleButton.LayoutTransform>
                                </ToggleButton>

                                <materialDesign:PackIcon
                                    Grid.Row="2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Kind="WeatherNight" />

                                <ToggleButton
                                    x:Name="ThemeToggle"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="5"
                                    Checked="ThemeToggle_Checked"
                                    Loaded="ThemeToggle_Loaded"
                                    Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                    Unchecked="ThemeToggle_Unchecked">
                                    <ToggleButton.LayoutTransform>
                                        <ScaleTransform ScaleX="0.7" ScaleY="0.7" />
                                    </ToggleButton.LayoutTransform>
                                </ToggleButton>

                            </Grid>
                        </materialDesign:PopupBox>

                    </UniformGrid>

                </materialDesign:ColorZone>
                <ContentControl x:Name="MainMenuContentArea" Grid.Row="1" />

                <!--  右側: ヘルプパネル（初期非表示）  -->
                <ScrollViewer
                    x:Name="HotKeyHelpScrollViewer"
                    Grid.RowSpan="2"
                    Grid.Column="1"
                    BorderThickness="1,0,0,0"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="Collapsed">

                    <ItemsControl x:Name="HelpItemsControl" Margin="8,6">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!--  セパレーター  -->
                                    <Separator Margin="0,2" />

                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Grid.Column="0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <!--  デフォルトのスタイル  -->
                                                    <Setter Property="BorderBrush" Value="Gray" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="CornerRadius" Value="3" />
                                                    <Setter Property="Padding" Value="5,1" />
                                                    <!--  Key が空のときは枠と余白を消す  -->
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Key}" Value="">
                                                            <Setter Property="BorderBrush" Value="Transparent" />
                                                            <Setter Property="BorderThickness" Value="0" />
                                                            <Setter Property="Padding" Value="0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Text="{Binding Key}" />
                                        </Border>

                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Text="{Binding Description}" />
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </ScrollViewer>
            </Grid>
        </materialDesign:DrawerHost>
        <!--  全面スピナーオーバーレイ（DrawerHostの後に配置することで最前面）  -->
        <Common:SpinnerOverlayPanel x:Name="ProgressRing" Visibility="Collapsed" />
    </Grid>
</Window>
