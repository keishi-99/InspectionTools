<UserControl
    x:Class="InspectionTools.Product.EL0122FIUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:InspectionTools.Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InspectionTools.Product"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="220"
    Height="240"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="0.5*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ComboBox
            x:Name="Dmm01ComboBox"
            Margin="10,0"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[DMM-V]" />
        <ComboBox
            x:Name="Dmm02ComboBox"
            Grid.Column="1"
            Margin="10,0"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[DMM-A]" />

        <ComboBox
            x:Name="FgComboBox"
            Grid.Row="1"
            Margin="10,0"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[FG]" />
        <ComboBox
            x:Name="OscComboBox"
            Grid.Row="1"
            Grid.Column="1"
            Margin="10,0"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[OSC]" />

        <ComboBox
            x:Name="PsComboBox"
            Grid.Row="2"
            Margin="10,0"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[DCS]" />

        <Button
            x:Name="ConnectButton"
            Grid.Row="3"
            Margin="20,0"
            VerticalAlignment="Center"
            Click="ConnectButton_Click"
            Content="接続" />
        <Button
            x:Name="ReleaseButton"
            Grid.Row="3"
            Grid.Column="1"
            Margin="20,0"
            VerticalAlignment="Center"
            Click="ReleaseButton_Click"
            Content="解除"
            IsEnabled="False" />

        <CheckBox
            x:Name="HotKeyChekBox"
            Grid.Row="4"
            Margin="20,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Checked="HotKeyChekBox_Checked"
            Content="HotKey"
            Unchecked="HotKeyChekBox_Unchecked" />

        <TextBlock
            Grid.Row="5"
            Grid.Column="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Text="待機時間(ms)" />
        <TextBox
            x:Name="WaitTimeTextBox"
            Grid.Row="4"
            Grid.Column="1"
            Margin="20,0"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Right"
            Text="5000" />


        <Common:WaitingCircle
            x:Name="ProgressRing"
            Grid.Row="1"
            Grid.RowSpan="4"
            Grid.ColumnSpan="2"
            Padding="20,20,20,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed" />

    </Grid>
</UserControl>
