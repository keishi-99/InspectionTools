<UserControl
    x:Class="InspectionTools.Product.EL4001UserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:InspectionTools.Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InspectionTools.Product"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="250"
    Height="260"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid" Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="0.5*" />
            <RowDefinition Height="0.5*" />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ComboBox
            x:Name="Dmm01ComboBox"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[DMM1]" />
        <ComboBox
            x:Name="Dmm02ComboBox"
            Grid.Column="1"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[DMM2]" />
        <ComboBox
            x:Name="OscComboBox"
            Grid.Row="1"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            IsEditable="True"
            IsReadOnly="True"
            Text="[OSC]" />
        <ComboBox
            x:Name="DcsComboBox"
            Grid.Row="1"
            Grid.Column="1"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            IsEditable="True"
            IsReadOnly="True"
            Text="[DCS]" />

        <TextBox
            x:Name="OscRangeLabel"
            Grid.Row="2"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            IsReadOnly="True"
            TextWrapping="Wrap" />

        <Grid
            x:Name="DcsGrid"
            Grid.Row="2"
            Grid.Column="1"
            Width="80">
            <TextBox
                x:Name="DcsNumberLabel"
                Width="25"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                IsReadOnly="True"
                TextWrapping="Wrap" />
            <TextBox
                x:Name="DcsRangeLabel"
                Width="50"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                IsReadOnly="True"
                TextWrapping="Wrap" />
        </Grid>

        <Button
            x:Name="ConnectButton"
            Grid.Row="3"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="ConnectButton_Click"
            Content="接続" />
        <Button
            x:Name="ReleaseButton"
            Grid.Row="3"
            Grid.Column="1"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="ReleaseButton_Click"
            Content="解除"
            IsEnabled="False" />

        <CheckBox
            x:Name="HotKeyChekBox"
            Grid.Row="4"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Checked="HotKeyChekBox_Checked"
            Content="HotKey"
            Style="{StaticResource {x:Type ToggleButton}}"
            Unchecked="HotKeyChekBox_Unchecked" />


        <Common:WaitingCircle
            x:Name="ProgressRing"
            Grid.RowSpan="5"
            Grid.ColumnSpan="3"
            Padding="20,20,20,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed" />

    </Grid>
</UserControl>
