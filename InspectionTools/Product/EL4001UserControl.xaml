<UserControl
    x:Class="InspectionTools.Product.EL4001UserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:InspectionTools.Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InspectionTools.Product"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="220"
    Height="230"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="0.25*" />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ComboBox
            x:Name="Dmm01ComboBox"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="DMM-1"
            IsReadOnly="True" />
        <ComboBox
            x:Name="Dmm02ComboBox"
            Grid.Column="1"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="DMM-2"
            IsReadOnly="True" />
        <ComboBox
            x:Name="OscComboBox"
            Grid.Row="1"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="OSC"
            IsReadOnly="True" />
        <ComboBox
            x:Name="DcsComboBox"
            Grid.Row="1"
            Grid.Column="1"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="DCS"
            IsReadOnly="True" />

        <TextBox
            x:Name="OscRangeLabel"
            Grid.Row="3"
            Margin="20,0"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Center"
            Focusable="False"
            IsReadOnly="True"
            TextWrapping="Wrap" />

        <Grid
            x:Name="DcsGrid"
            Grid.Row="3"
            Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>
            <TextBox
                x:Name="DcsNumberLabel"
                Margin="5,0"
                VerticalAlignment="Center"
                HorizontalContentAlignment="Center"
                Focusable="False"
                IsReadOnly="True"
                TextWrapping="Wrap" />
            <TextBox
                x:Name="DcsRangeLabel"
                Grid.Column="1"
                Margin="5,0"
                VerticalAlignment="Center"
                HorizontalContentAlignment="Center"
                Focusable="False"
                IsReadOnly="True"
                TextWrapping="Wrap" />
        </Grid>

        <Button
            x:Name="ConnectButton"
            Grid.Row="4"
            Margin="20,0"
            VerticalAlignment="Center"
            Click="ConnectButton_Click"
            Content="接続" />
        <Button
            x:Name="ReleaseButton"
            Grid.Row="4"
            Grid.Column="1"
            Margin="20,0"
            VerticalAlignment="Center"
            Click="ReleaseButton_Click"
            Content="解除"
            IsEnabled="False" />

        <CheckBox
            x:Name="HotKeyCheckBox"
            Grid.Row="5"
            Margin="20,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Checked="HotKeyCheckBox_Checked"
            Content="HotKey"
            Unchecked="HotKeyCheckBox_Unchecked" />


        <Common:WaitingCircle
            x:Name="ProgressRing"
            Grid.RowSpan="6"
            Grid.ColumnSpan="2"
            Padding="20,20,20,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed" />

    </Grid>
</UserControl>
