<UserControl
    x:Class="InspectionTools.Product.EL0137UserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:InspectionTools.Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InspectionTools.Product"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="220"
    Height="240"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

    <Grid
        x:Name="MainGrid"
        Margin="10"
        ColumnDefinitions="*,*"
        RowDefinitions="*,0.25*,*,*,0.25*,*,*">

        <ComboBox
            x:Name="DmmComboBox"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="DMM"
            IsReadOnly="True" />
        <ComboBox
            x:Name="OscComboBox"
            Grid.Column="1"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="OSC"
            IsReadOnly="True" />

        <Button
            x:Name="ConnectButton"
            Grid.Row="2"
            Margin="20,0"
            VerticalAlignment="Center"
            Click="ConnectButton_Click"
            Content="接続" />
        <Button
            x:Name="ReleaseButton"
            Grid.Row="2"
            Grid.Column="1"
            Margin="20,0"
            VerticalAlignment="Center"
            Click="ReleaseButton_Click"
            Content="解除"
            IsEnabled="False" />

        <CheckBox
            x:Name="HotKeyCheckBox"
            Grid.Row="3"
            Margin="20,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Checked="HotKeyCheckBox_Checked"
            Content="HotKey"
            Unchecked="HotKeyCheckBox_Unchecked" />

        <Button
            x:Name="OscRotateButton"
            Grid.Row="5"
            Grid.ColumnSpan="2"
            Margin="70,0"
            Click="OscRotateButton_Click"
            Content="OSC"
            IsEnabled="False" />

        <TextBox
            x:Name="OscRotateRangeTextBox"
            Grid.Row="6"
            Grid.ColumnSpan="2"
            Margin="30,0"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Focusable="False"
            IsReadOnly="true" />


        <Common:SpinnerOverlayPanel
            x:Name="ProgressRing"
            Grid.RowSpan="7"
            Grid.ColumnSpan="2"
            Padding="20,20,20,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed" />

    </Grid>
</UserControl>
