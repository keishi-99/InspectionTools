<UserControl
    x:Class="InspectionTools.Product.EL0137UserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:InspectionTools.Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InspectionTools.Product"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="250"
    Height="300"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid" Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="0.5*" />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ComboBox
            x:Name="DmmComboBox"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[DMM]" />
        <ComboBox
            x:Name="OscComboBox"
            Grid.Column="1"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[OSC]" />

        <Button
            x:Name="ConnectButton"
            Grid.Row="1"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="ConnectButton_Click"
            Content="接続" />
        <Button
            x:Name="ReleaseButton"
            Grid.Row="1"
            Grid.Column="1"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="ReleaseButton_Click"
            Content="解除"
            IsEnabled="False" />

        <CheckBox
            x:Name="HotKeyChekBox"
            Grid.Row="2"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Checked="HotKeyChekBox_Checked"
            Content="HotKey"
            Style="{StaticResource {x:Type ToggleButton}}"
            Unchecked="HotKeyChekBox_Unchecked" />

        <Button
            x:Name="OscRotateButton"
            Grid.Row="4"
            Grid.ColumnSpan="2"
            Width="60"
            Height="30"
            HorizontalAlignment="Center"
            Click="OscRotateButton_Click"
            Content="OSC"
            IsEnabled="False" />

        <TextBox
            x:Name="OscRotateRangeTextBox"
            Grid.Row="5"
            Grid.ColumnSpan="2"
            Width="120"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center" />

        <TextBlock
            x:Name="Time"
            Grid.Row="6"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontFamily="Meiryo"
            FontSize="15"
            FontWeight="Bold"
            TextAlignment="Center"
            TextWrapping="Wrap">
            <Run Language="ja-jp" Text="00:00:00" />
        </TextBlock>


        <Common:WaitingCircle
            x:Name="ProgressRing"
            Grid.RowSpan="8"
            Grid.ColumnSpan="2"
            Padding="20,20,20,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed" />

    </Grid>
</UserControl>
