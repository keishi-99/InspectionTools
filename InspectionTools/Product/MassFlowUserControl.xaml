<UserControl
    x:Class="InspectionTools.Product.MassFlowUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:InspectionTools.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InspectionTools.Product"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="320"
    Height="380"
    Loaded="UserControl_Loaded"
    Unloaded="UserControl_Unloaded"
    mc:Ignorable="d">

    <Grid
        x:Name="MainGrid"
        Margin="10"
        RowDefinitions="3*,0.5*,5.5*">

        <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*,*">

            <!--  1  -->
            <ComboBox
                x:Name="DmmComboBox"
                Margin="5,0"
                VerticalAlignment="Center"
                materialDesign:HintAssist.Hint="DMM"
                IsReadOnly="True" />
            <ComboBox
                x:Name="DcsComboBox"
                Grid.Row="1"
                Margin="5,0"
                VerticalAlignment="Center"
                materialDesign:HintAssist.Hint="DCS"
                IsReadOnly="True" />

            <!--  2  -->
            <ComboBox
                x:Name="FgNumberComboBox"
                Grid.Column="1"
                Margin="5,0"
                VerticalAlignment="Center"
                materialDesign:HintAssist.Hint="FG数"
                IsReadOnly="True"
                SelectedIndex="0"
                SelectionChanged="FgNumberComboBox_SelectionChanged">
                <ComboBoxItem Content="1" />
                <ComboBoxItem Content="2" />
            </ComboBox>
            <Grid
                x:Name="FgNumberGrid1"
                Grid.Row="1"
                Grid.Column="1"
                Visibility="Visible">
                <ComboBox
                    x:Name="Fg01ComboBox"
                    Margin="5,0"
                    VerticalAlignment="Center"
                    materialDesign:HintAssist.Hint="FG"
                    IsReadOnly="True" />
            </Grid>
            <Grid
                x:Name="FgNumberGrid2"
                Grid.Row="1"
                Grid.RowSpan="2"
                Grid.Column="1"
                RowDefinitions="*,*"
                Visibility="Collapsed">
                <ComboBox
                    x:Name="Fg02_1ComboBox"
                    Margin="5,0"
                    VerticalAlignment="Center"
                    materialDesign:HintAssist.Hint="FG1"
                    IsReadOnly="True" />
                <ComboBox
                    x:Name="Fg02_2ComboBox"
                    Grid.Row="1"
                    Margin="5,0"
                    VerticalAlignment="Center"
                    materialDesign:HintAssist.Hint="FG2"
                    IsReadOnly="True" />
            </Grid>

            <!--  3  -->
            <Button
                x:Name="ConnectButton"
                Grid.Column="2"
                Margin="20,0"
                VerticalAlignment="Center"
                Click="ConnectButton_Click"
                Content="接続" />
            <Button
                x:Name="ReleaseButton"
                Grid.Row="1"
                Grid.Column="3"
                Margin="20,0"
                VerticalAlignment="Center"
                Click="ReleaseButton_Click"
                Content="解除"
                IsEnabled="False" />
            <ComboBox
                x:Name="OscComboBox"
                Grid.Row="2"
                Margin="5,0"
                VerticalAlignment="Center"
                materialDesign:HintAssist.Hint="OSC"
                IsReadOnly="True" />
            <CheckBox
                x:Name="HotKeyCheckBox"
                Grid.Row="2"
                Grid.Column="2"
                Margin="20,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Checked="HotKeyCheckBox_Checked"
                Content="HotKey"
                Unchecked="HotKeyCheckBox_Unchecked" />
        </Grid>

        <Grid
            Grid.Row="2"
            ColumnDefinitions="*,*,*,*,*"
            RowDefinitions="*,*,0.25*,*,*,0.25*,*">

            <!--  1  -->
            <Grid Grid.ColumnSpan="5" Margin="100,4">
                <TextBox
                    x:Name="DcsNumberTextBox"
                    HorizontalContentAlignment="Center"
                    Focusable="False"
                    FontWeight="Bold"
                    IsReadOnly="True"
                    TextWrapping="NoWrap" />
            </Grid>
            <!--  2  -->
            <Button
                x:Name="DcsOffButton"
                Grid.Row="1"
                Margin="10,0"
                Padding="1"
                VerticalAlignment="Center"
                Click="DcsOffButton_Click"
                Content="OFF" />
            <Button
                x:Name="Dcs2VButton"
                Grid.Row="1"
                Grid.Column="1"
                Margin="10,0"
                Padding="1"
                VerticalAlignment="Center"
                Click="Dcs2VButton_Click"
                Content="2V" />
            <Button
                x:Name="Dcs8VButton"
                Grid.Row="1"
                Grid.Column="2"
                Margin="10,0"
                Padding="1"
                VerticalAlignment="Center"
                Click="Dcs8VButton_Click"
                Content="8V" />
            <Button
                x:Name="Dcs1VButton"
                Grid.Row="1"
                Grid.Column="3"
                Margin="10,0"
                Padding="1"
                VerticalAlignment="Center"
                Click="Dcs1VButton_Click"
                Content="1V" />
            <Button
                x:Name="Dcs7VButton"
                Grid.Row="1"
                Grid.Column="4"
                Margin="10,0"
                Padding="1"
                VerticalAlignment="Center"
                Click="Dcs7VButton_Click"
                Content="7V" />

            <!--  3  -->
            <!--  4  -->
            <Grid
                Grid.Row="3"
                Grid.ColumnSpan="5"
                Margin="40,4">
                <TextBox
                    x:Name="FgOscNumberTextBox"
                    HorizontalContentAlignment="Center"
                    Focusable="False"
                    FontWeight="Bold"
                    IsReadOnly="True"
                    TextWrapping="NoWrap" />
            </Grid>
            <!--  5  -->
            <Button
                x:Name="FgOscRotationRButton"
                Grid.Row="4"
                Grid.Column="2"
                Margin="10,0"
                Padding="1"
                Click="FgOscRotationRButton_Click"
                Content="◀"
                IsEnabled="False"
                Style="{StaticResource MaterialDesignPaperButton}" />
            <StackPanel
                Grid.Row="4"
                Grid.Column="1"
                VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center" Text="FG" />
                <TextBlock HorizontalAlignment="Center" Text="OSC" />
            </StackPanel>
            <Button
                x:Name="FgOscRotationButton"
                Grid.Row="4"
                Grid.Column="3"
                Margin="10,0"
                Padding="1"
                Click="FgOscRotationButton_Click"
                Content="▶"
                IsEnabled="False"
                Style="{StaticResource MaterialDesignPaperButton}" />

            <!--  6  -->
            <!--  7  -->
            <Grid
                Grid.Row="6"
                Grid.ColumnSpan="5"
                Margin="60,4"
                VerticalAlignment="Center"
                ColumnDefinitions="*,2*">
                <CheckBox
                    x:Name="SerialLockCheckBox"
                    Margin="15,0"
                    HorizontalAlignment="Stretch"
                    Checked="SerialLockCheckBox_Checked"
                    Content="🔒️"
                    Unchecked="SerialLockCheckBox_Unchecked" />

                <Grid Grid.Column="1">
                    <TextBox
                        x:Name="SerialTextBox"
                        Margin="2,2,20,2"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        MaxLength="8"
                        MaxLines="1" />
                    <UniformGrid
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Columns="1"
                        Rows="2">
                        <Button
                            Height="Auto"
                            Padding="1"
                            Click="SerialNext_Click"
                            Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                            Style="{StaticResource MaterialDesignToolButton}">
                            <materialDesign:PackIcon Kind="Plus" />
                        </Button>
                        <Button
                            Height="Auto"
                            Padding="1"
                            Click="SerialBack_Click"
                            Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                            Style="{StaticResource MaterialDesignToolButton}">
                            <materialDesign:PackIcon Kind="Minus" />
                        </Button>
                    </UniformGrid>
                </Grid>
            </Grid>

        </Grid>

    </Grid>
</UserControl>
