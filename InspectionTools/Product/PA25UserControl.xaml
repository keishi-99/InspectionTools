<UserControl
    x:Class="InspectionTools.Product.PA25UserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:InspectionTools.Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InspectionTools.Product"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="250"
    Height="300"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid" Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ComboBox
            x:Name="OscComboBox"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[OSC]" />
        <ComboBox
            x:Name="FgComboBox"
            Grid.Column="1"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[FG]" />

        <ComboBox
            x:Name="DmmComboBox"
            Grid.Row="1"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[DMM]" />

        <Button
            x:Name="ConnectButton"
            Grid.Row="2"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="ConnectButton_Click"
            Content="接続" />
        <Button
            x:Name="ReleaseButton"
            Grid.Row="2"
            Grid.Column="1"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="ReleaseButton_Click"
            Content="解除"
            IsEnabled="False" />

        <CheckBox
            x:Name="HotKeyChekBox"
            Grid.Row="3"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Checked="HotKeyChekBox_Checked"
            Content="HotKey"
            Style="{StaticResource {x:Type ToggleButton}}"
            Unchecked="HotKeyChekBox_Unchecked" />

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.5*" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="OSC" />
            <UniformGrid
                Grid.Row="1"
                HorizontalAlignment="Center"
                Rows="1">
                <Button
                    x:Name="OscRotateRButton"
                    Width="30"
                    Height="20"
                    Margin="5"
                    HorizontalAlignment="Center"
                    Click="OscRotateRButton_Click"
                    Content="◀"
                    IsEnabled="False" />
                <Button
                    x:Name="OscRotateButton"
                    Width="30"
                    Height="20"
                    Margin="5"
                    HorizontalAlignment="Center"
                    Click="OscRotateButton_Click"
                    Content="▶"
                    IsEnabled="False" />
            </UniformGrid>
        </Grid>
        <Grid Grid.Row="4" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.5*" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="FG" />
            <UniformGrid
                Grid.Row="1"
                HorizontalAlignment="Center"
                Rows="1">
                <Button
                    x:Name="FgRotateRButton"
                    Width="30"
                    Height="20"
                    Margin="5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="FgRotateRButton_Click"
                    Content="◀"
                    IsEnabled="False" />
                <Button
                    x:Name="FgRotateButton"
                    Width="30"
                    Height="20"
                    Margin="5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="FgRotateButton_Click"
                    Content="▶"
                    IsEnabled="False" />
            </UniformGrid>
        </Grid>

        <TextBox
            x:Name="OscRotateRangeTextBox"
            Grid.Row="5"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            IsReadOnly="True" />
        <TextBox
            x:Name="FgRotateRangeTextBox"
            Grid.Row="5"
            Grid.Column="1"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            IsReadOnly="True" />


        <Common:WaitingCircle
            x:Name="ProgressRing"
            Grid.RowSpan="5"
            Grid.ColumnSpan="2"
            Padding="20,20,20,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed" />

    </Grid>
</UserControl>
