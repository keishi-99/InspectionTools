<UserControl
    x:Class="InspectionTools.Product.PA25UserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:InspectionTools.Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InspectionTools.Product"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="220"
    Height="300"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="0.25*" />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="0.25*" />
            <RowDefinition Height="0.5*" />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ComboBox
            x:Name="DmmComboBox"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="DMM"
            IsReadOnly="True" />

        <ComboBox
            x:Name="FgComboBox"
            Grid.Row="1"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="FG"
            IsReadOnly="True" />
        <ComboBox
            x:Name="OscComboBox"
            Grid.Row="1"
            Grid.Column="1"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="OSC"
            IsReadOnly="True" />

        <Button
            x:Name="ConnectButton"
            Grid.Row="3"
            Margin="20,0"
            VerticalAlignment="Center"
            Click="ConnectButton_Click"
            Content="接続" />
        <Button
            x:Name="ReleaseButton"
            Grid.Row="3"
            Grid.Column="1"
            Margin="20,0"
            VerticalAlignment="Center"
            Click="ReleaseButton_Click"
            Content="解除"
            IsEnabled="False" />

        <CheckBox
            x:Name="HotKeyChekBox"
            Grid.Row="4"
            Margin="20,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Checked="HotKeyCheckBox_Checked"
            Content="HotKey"
            Unchecked="HotKeyCheckBox_Unchecked" />

        <TextBlock
            Grid.Row="6"
            Grid.Column="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Text="FG" />
        <UniformGrid
            Grid.Row="7"
            Grid.Column="0"
            Margin="10,0"
            Rows="1">
            <Button
                x:Name="FgRotateRButton"
                Margin="5,0"
                VerticalAlignment="Center"
                Click="FgRotateRButton_Click"
                Content="◀"
                IsEnabled="False" />
            <Button
                x:Name="FgRotateButton"
                Margin="5,0"
                VerticalAlignment="Center"
                Click="FgRotateButton_Click"
                Content="▶"
                IsEnabled="False" />
        </UniformGrid>

        <TextBlock
            Grid.Row="6"
            Grid.Column="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Text="OSC" />
        <UniformGrid
            Grid.Row="7"
            Grid.Column="1"
            Margin="10,0"
            Rows="1">
            <Button
                x:Name="OscRotateRButton"
                Margin="5,0"
                Click="OscRotateRButton_Click"
                Content="◀"
                IsEnabled="False" />
            <Button
                x:Name="OscRotateButton"
                Margin="5,0"
                Click="OscRotateButton_Click"
                Content="▶"
                IsEnabled="False" />
        </UniformGrid>

        <TextBox
            x:Name="FgRotateRangeTextBox"
            Grid.Row="8"
            Margin="10,0"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Focusable="False"
            IsReadOnly="True" />
        <TextBox
            x:Name="OscRotateRangeTextBox"
            Grid.Row="8"
            Grid.Column="1"
            Margin="10,0"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Focusable="False"
            IsReadOnly="True" />


        <Common:WaitingCircle
            x:Name="ProgressRing"
            Grid.RowSpan="9"
            Grid.ColumnSpan="2"
            Padding="20,20,20,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed" />

    </Grid>
</UserControl>
