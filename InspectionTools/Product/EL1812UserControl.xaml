<UserControl
    x:Class="InspectionTools.Product.EL1812UserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:InspectionTools.Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InspectionTools.Product"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="320"
    Height="360"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" />
            <RowDefinition Height="5*" />
        </Grid.RowDefinitions>

        <Grid x:Name="MainGrid01" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!--  1  -->
            <ComboBox
                x:Name="FgComboBox"
                Margin="10,0"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[FG]" />
            <ComboBox
                x:Name="DmmComboBox"
                Grid.Row="1"
                Margin="10,0"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[DMM]" />
            <ComboBox
                x:Name="OscComboBox"
                Grid.Row="2"
                Margin="10,0"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[OSC]" />

            <!--  3  -->
            <Button
                x:Name="ConnectButton"
                Grid.Row="1"
                Grid.Column="1"
                Margin="20,0"
                VerticalAlignment="Center"
                Click="ConnectButton_Click"
                Content="接続" />
            <Button
                x:Name="ReleaseButton"
                Grid.Row="1"
                Grid.Column="2"
                Margin="20,0"
                VerticalAlignment="Center"
                Click="ReleaseButton_Click"
                Content="解除"
                IsEnabled="False" />
            <CheckBox
                x:Name="HotKeyChekBox"
                Grid.Row="2"
                Grid.Column="1"
                Margin="20,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Checked="HotKeyChekBox_Checked"
                Content="HotKey"
                Unchecked="HotKeyChekBox_Unchecked" />
        </Grid>

        <Grid
            x:Name="MainGrid02"
            Grid.Row="1"
            Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Grid
                Grid.Row="0"
                Grid.Column="0"
                Margin="30,0"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Label
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="OSC" />
                <TextBox
                    x:Name="OscRotateRangeTextBox"
                    Grid.Column="1"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    IsReadOnly="True"
                    Text="---"
                    TextAlignment="Center" />
            </Grid>

            <Button
                x:Name="OscRotationButton"
                Grid.Row="1"
                Margin="45,0"
                VerticalAlignment="Center"
                Click="OscRotationButton_Click"
                Content="OSC"
                IsEnabled="False" />

            <Grid
                Grid.Row="2"
                Margin="5,0"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Label
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="Menu" />
                <TextBox
                    x:Name="MenuRotateRangeTextBox"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    IsReadOnly="True"
                    Text="01"
                    TextAlignment="Center" />
                <Button
                    x:Name="MenuRotateBackButton"
                    Grid.Column="2"
                    Margin="5,0"
                    Click="MenuRotateBackButton_Click"
                    Content="◀" />
                <Button
                    x:Name="MenuRotateNextButton"
                    Grid.Column="3"
                    Margin="5,0"
                    Click="MenuRotateNextButton_Click"
                    Content="▶" />
            </Grid>


            <Grid
                Grid.Row="0"
                Grid.Column="1"
                Margin="30,0"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Label
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="FG" />
                <TextBox
                    x:Name="FgRotateRangeTextBox"
                    Grid.Column="1"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    IsReadOnly="True"
                    Text="---"
                    TextAlignment="Center" />
            </Grid>

            <Grid
                Grid.Row="1"
                Grid.Column="1"
                Margin="35,0"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="FgRotateBackButton"
                    Margin="5,0"
                    Click="FgRotateBackButton_Click"
                    Content="◀"
                    IsEnabled="False" />
                <Button
                    x:Name="FgRotateNextButton"
                    Grid.Column="1"
                    Margin="5,0"
                    Click="FgRotateNextButton_Click"
                    Content="▶"
                    IsEnabled="False" />
            </Grid>

            <Grid
                Grid.Row="2"
                Grid.Column="1"
                Margin="10,0"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="FgTriggerButton"
                    Margin="5,0"
                    VerticalAlignment="Center"
                    Click="FgTriggerButton_Click"
                    Content="TRG"
                    IsEnabled="False" />
                <Button
                    x:Name="FgOutputOnButton"
                    Grid.Column="1"
                    Margin="5,0"
                    Click="FgOutputOnButton_Click"
                    Content="ON"
                    IsEnabled="False" />
                <Button
                    x:Name="FgOutputOffButton"
                    Grid.Column="2"
                    Margin="5,0"
                    Click="FgOutputOffButton_Click"
                    Content="OFF"
                    IsEnabled="False" />
            </Grid>

            <Grid
                Grid.Row="3"
                Grid.ColumnSpan="4"
                Margin="40,0"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="2.5*" />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <CheckBox
                    x:Name="SerialLockCheckBox"
                    Margin="5,0"
                    HorizontalAlignment="Stretch"
                    Checked="SerialLockCheckBox_Checked"
                    Content="🔒️"
                    Unchecked="SerialLockCheckBox_Unchecked" />
                <TextBox
                    x:Name="SerialTextBox"
                    Grid.Column="1"
                    Margin="5"
                    HorizontalContentAlignment="Right"
                    MaxLength="8"
                    MaxLines="1" />
                <Button
                    x:Name="SerialBack"
                    Grid.Column="2"
                    Margin="5,0"
                    Click="SerialBack_Click"
                    Content="◀" />
                <Button
                    x:Name="SerialNext"
                    Grid.Column="3"
                    Margin="5,0"
                    Click="SerialNext_Click"
                    Content="▶" />
            </Grid>


            <Grid
                Grid.Row="4"
                Grid.ColumnSpan="4"
                Margin="40,0"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="2.5*" />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <CheckBox
                    x:Name="CountLockCheckBox"
                    Margin="5,0"
                    HorizontalAlignment="Stretch"
                    Checked="CountLockCheckBox_Checked"
                    Content="🔒️"
                    Unchecked="CountLockCheckBox_Unchecked" />
                <Grid Grid.Column="1" Margin="50,0,0,0">
                    <TextBox
                        x:Name="CountTextBox"
                        Grid.ColumnSpan="2"
                        Margin="5"
                        HorizontalContentAlignment="Right"
                        MaxLength="2"
                        MaxLines="1" />
                </Grid>
                <Button
                    x:Name="CountBack"
                    Grid.Column="2"
                    Margin="5,0"
                    Click="CountBack_Click"
                    Content="◀" />
                <Button
                    x:Name="CountNext"
                    Grid.Column="3"
                    Margin="5,0"
                    Click="CountNext_Click"
                    Content="▶" />
            </Grid>





        </Grid>


        <Common:WaitingCircle
            x:Name="ProgressRing"
            Grid.Row="2"
            Grid.RowSpan="8"
            Grid.ColumnSpan="4"
            Padding="20,20,20,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed" />
    </Grid>
</UserControl>
