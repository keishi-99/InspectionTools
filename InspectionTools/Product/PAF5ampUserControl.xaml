<UserControl
    x:Class="InspectionTools.Product.PAF5ampUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:InspectionTools.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InspectionTools.Product"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="220"
    Height="190"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

    <Grid
        x:Name="MainGrid"
        Margin="10"
        ColumnDefinitions="*,*"
        RowDefinitions="*,*,0.25*,*,*">

        <ComboBox
            x:Name="DcsComboBox"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="DCS"
            IsReadOnly="True" />
        <ComboBox
            x:Name="DmmComboBox"
            Grid.Column="1"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="DMM"
            IsReadOnly="True" />

        <ComboBox
            x:Name="FgComboBox"
            Grid.Row="1"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="FG"
            IsReadOnly="True" />
        <ComboBox
            x:Name="OscComboBox"
            Grid.Row="1"
            Grid.Column="1"
            Margin="5,0"
            VerticalAlignment="Center"
            materialDesign:HintAssist.Hint="OSC"
            IsReadOnly="True" />

        <Button
            x:Name="ConnectButton"
            Grid.Row="3"
            Margin="20,0"
            VerticalAlignment="Center"
            Click="ConnectButton_Click"
            Content="接続" />
        <Button
            x:Name="ReleaseButton"
            Grid.Row="3"
            Grid.Column="1"
            Margin="20,0"
            VerticalAlignment="Center"
            Click="ReleaseButton_Click"
            Content="解除"
            IsEnabled="False" />

        <CheckBox
            x:Name="HotKeyCheckBox"
            Grid.Row="4"
            Margin="20,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Checked="HotKeyCheckBox_Checked"
            Content="HotKey"
            Unchecked="HotKeyCheckBox_Unchecked" />


        <Common:SpinnerOverlayPanel
            x:Name="ProgressRing"
            Grid.RowSpan="5"
            Grid.ColumnSpan="2"
            Visibility="Collapsed" />

    </Grid>
</UserControl>
