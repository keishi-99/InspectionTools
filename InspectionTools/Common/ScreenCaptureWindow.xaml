<Window
    x:Class="InspectionTools.Common.ScreenCaptureWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InspectionTools.Common"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ScreenCaptureWindow"
    Margin="0"
    Padding="0"
    AllowsTransparency="True"
    Background="Transparent"
    Cursor="Cross"
    Loaded="Window_Loaded"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None">
    <Canvas
        Name="LayoutRoot"
        Margin="0"
        Background="Transparent">
        <Path
            Margin="0"
            Fill="#80111111"
            MouseLeftButtonDown="DrawingPath_MouseLeftButtonDown"
            MouseLeftButtonUp="DrawingPath_MouseLeftButtonUp"
            MouseMove="DrawingPath_MouseMove"
            Stroke="Black"
            StrokeThickness="1">
            <Path.Data>
                <CombinedGeometry x:Name="ScreenArea" GeometryCombineMode="Xor" />
            </Path.Data>
        </Path>
        <!--  枠線用（点線）  -->
        <Path
            x:Name="SelectionBorder"
            Stroke="White"
            StrokeDashArray="4 2"
            StrokeDashCap="Round"
            StrokeThickness="2"
            Visibility="Collapsed" />
    </Canvas>
</Window>
