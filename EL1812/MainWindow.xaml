<Window
    x:Class="EL1812.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:Tools.Common.Tool;assembly=Tools.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:EL1812"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="EL1812"
    Width="300"
    Height="300"
    Icon="sine.ico"
    ResizeMode="CanMinimize"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid x:Name="MainGrid01" Margin="10,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <ComboBox
                x:Name="FgComboBox"
                Width="70"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[FG]" />

            <ComboBox
                x:Name="DmmComboBox"
                Grid.Row="1"
                Width="70"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[DMM]" />

            <ComboBox
                x:Name="OscComboBox"
                Grid.Row="2"
                Width="70"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[OSC]" />


            <Button
                x:Name="ConnectButton"
                Grid.Column="1"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="ConnectButton_Click"
                Content="接続" />

            <CheckBox
                x:Name="HotKeyChekBox"
                Grid.Row="1"
                Grid.Column="1"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Checked="HotKeyChekBox_Checked"
                Content="HotKey"
                Style="{StaticResource {x:Type ToggleButton}}"
                Unchecked="HotKeyChekBox_Unchecked" />



            <Button
                x:Name="ReleaseButton"
                Grid.Column="3"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="ReleaseButton_Click"
                Content="解除"
                IsEnabled="False" />

            <CheckBox
                x:Name="TopMostCheckBox"
                Grid.Row="1"
                Grid.Column="3"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Checked="TopMostCheckBox_Checked"
                Content="最前面"
                Style="{StaticResource {x:Type ToggleButton}}"
                Unchecked="TopMostCheckBox_Unchecked" />

            <Button
                x:Name="InstListButton"
                Grid.Row="2"
                Grid.Column="3"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="InstListButton_Click"
                Content="測定器" />
        </Grid>

        <Grid
            x:Name="MainGrid02"
            Grid.Row="1"
            Margin="10,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Label
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="OSC" />
                <TextBox
                    x:Name="OscRotateRangeTextBox"
                    Width="50"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    IsReadOnly="True"
                    Text="---"
                    TextAlignment="Center" />
            </StackPanel>

            <Button
                x:Name="OscRotationButton"
                Grid.Row="1"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="OscRotationButton_Click"
                Content="OSC"
                IsEnabled="False" />

            <StackPanel
                Grid.Row="2"
                Grid.Column="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Label
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="Menu" />
                <TextBox
                    x:Name="MenuRotateRangeTextBox"
                    Width="30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    IsReadOnly="True"
                    Text="01"
                    TextAlignment="Center" />
            </StackPanel>

            <StackPanel
                Grid.Row="3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    x:Name="MenuRotateBackButton"
                    Width="30"
                    Margin="0,0,10,0"
                    HorizontalAlignment="Center"
                    Click="MenuRotateBackButton_Click"
                    Content="&lt;&lt;" />
                <Button
                    x:Name="MenuRotateNextButton"
                    Width="30"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Center"
                    Click="MenuRotateNextButton_Click"
                    Content="&gt;&gt;" />
            </StackPanel>




            <StackPanel
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Label
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="FG" />
                <TextBox
                    x:Name="FgRotateRangeTextBox"
                    Width="50"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    IsReadOnly="True"
                    Text="---"
                    TextAlignment="Center" />
            </StackPanel>

            <StackPanel
                Grid.Row="1"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    x:Name="FgRotateBackButton"
                    Width="30"
                    Margin="0,0,10,0"
                    HorizontalAlignment="Center"
                    Click="FgRotateBackButton_Click"
                    Content="&lt;&lt;"
                    IsEnabled="False" />
                <Button
                    x:Name="FgRotateNextButton"
                    Width="30"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Center"
                    Click="FgRotateNextButton_Click"
                    Content="&gt;&gt;"
                    IsEnabled="False" />
            </StackPanel>

            <StackPanel
                Grid.Row="2"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    x:Name="FgOutputOnButton"
                    Width="30"
                    Margin="0,0,10,0"
                    HorizontalAlignment="Center"
                    Click="FgOutputOnButton_Click"
                    Content="ON"
                    IsEnabled="False" />
                <Button
                    x:Name="FgOutputOffButton"
                    Width="30"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Center"
                    Click="FgOutputOffButton_Click"
                    Content="OFF"
                    IsEnabled="False" />
            </StackPanel>

            <Button
                x:Name="FgTriggerButton"
                Grid.Row="3"
                Grid.Column="1"
                Width="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="FgTriggerButton_Click"
                Content="TRG"
                IsEnabled="False" />


            <StackPanel
                Grid.Row="4"
                Grid.ColumnSpan="2"
                Margin="0,0,50,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <CheckBox
                    x:Name="SerialLockCheckBox"
                    Width="20"
                    Checked="SerialLockCheckBox_Checked"
                    Content="🔒️"
                    Style="{StaticResource {x:Type ToggleButton}}"
                    Unchecked="SerialLockCheckBox_Unchecked" />
                <TextBox
                    x:Name="SerialTextBox"
                    Width="80"
                    Margin="10,0,0,0"
                    MaxLength="8"
                    MaxLines="1" />
                <Button
                    x:Name="SerialBack"
                    Width="20"
                    Margin="10,0,0,0"
                    Click="SerialBack_Click"
                    Content="◀" />
                <Button
                    x:Name="SerialNext"
                    Width="20"
                    Margin="5,0,0,0"
                    Click="SerialNext_Click"
                    Content="▶" />
            </StackPanel>


            <StackPanel
                Grid.Row="5"
                Grid.ColumnSpan="2"
                Margin="0,0,50,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <CheckBox
                    x:Name="CountLockCheckBox"
                    Width="20"
                    Checked="CountLockCheckBox_Checked"
                    Content="🔒️"
                    Style="{StaticResource {x:Type ToggleButton}}"
                    Unchecked="CountLockCheckBox_Unchecked" />
                <TextBox
                    x:Name="CountTextBox"
                    Width="30"
                    Margin="10,0,0,0"
                    MaxLength="8"
                    MaxLines="1" />
                <Button
                    x:Name="CountBack"
                    Width="20"
                    Margin="10,0,0,0"
                    Click="CountBack_Click"
                    Content="◀" />
                <Button
                    x:Name="CountNext"
                    Width="20"
                    Margin="5,0,0,0"
                    Click="CountNext_Click"
                    Content="▶" />
            </StackPanel>





        </Grid>

        <Common:WaitingCircle
            x:Name="ProgressRing"
            Grid.Row="2"
            Grid.RowSpan="8"
            Grid.ColumnSpan="4"
            Padding="20,20,20,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed" />
    </Grid>
</Window>
