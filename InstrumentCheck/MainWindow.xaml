<Window
    x:Class="InstrumentCheck.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:Tools.Common.Tool;assembly=Tools.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InstrumentCheck"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="InstrumentCheck"
    Width="600"
    Height="350"
    Icon="/power.ico"
    ResizeMode="CanMinimize"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid" Margin="10,10,10,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <ComboBox
                x:Name="Dmm01ComboBox"
                Width="80"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[DMM-1]" />
            <ComboBox
                x:Name="Dmm02ComboBox"
                Grid.Column="1"
                Width="80"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[DMM-2]" />
            <ComboBox
                x:Name="Dmm03ComboBox"
                Grid.Column="2"
                Width="80"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[DMM-3]" />


            <ComboBox
                x:Name="DcsComboBox"
                Grid.Row="1"
                Width="80"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[DCS]" />
            <Button
                x:Name="ConnectButton"
                Grid.Row="1"
                Grid.Column="1"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="ConnectButton_Click"
                Content="接続" />
            <Button
                x:Name="ReleaseButton"
                Grid.Row="1"
                Grid.Column="2"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="ReleaseButton_Click"
                Content="解除"
                IsEnabled="False" />


            <Button
                x:Name="InstListButton"
                Grid.Row="2"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="InstListButton_Click"
                Content="測定器" />

            <CheckBox
                x:Name="HotKeyChekBox"
                Grid.Row="2"
                Grid.Column="1"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Checked="HotKeyChekBox_Checked"
                Content="HotKey"
                Style="{StaticResource {x:Type ToggleButton}}"
                Unchecked="HotKeyChekBox_Unchecked" />

            <CheckBox
                x:Name="TopMostCheckBox"
                Grid.Row="2"
                Grid.Column="2"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Checked="TopMostCheckBox_Checked"
                Content="最前面"
                Style="{StaticResource {x:Type ToggleButton}}"
                Unchecked="TopMostCheckBox_Unchecked" />


            <TextBox
                x:Name="DcsRangeTextBox"
                Grid.Row="3"
                Grid.Column="1"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                IsReadOnly="True" />


            <StackPanel
                Grid.Row="3"
                Grid.Column="2"
                VerticalAlignment="Bottom">
                <TextBlock HorizontalAlignment="Center" Text="待機時間(ms)" />

                <TextBox
                    x:Name="WaitTimeTextBox"
                    Width="60"
                    HorizontalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Text="5000" />
            </StackPanel>


            <ProgressBar
                x:Name="ProgressBar"
                Grid.Row="4"
                Grid.ColumnSpan="3"
                Height="20"
                IsEnabled="False"
                Maximum="100"
                Minimum="0"
                Visibility="Visible"
                Value="0" />


            <Button
                x:Name="DcsStanbyButton"
                Grid.Row="5"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="DcsStanbyButton_Click"
                Content="STBY"
                IsEnabled="False" />
            <Button
                x:Name="AutoButton"
                Grid.Row="5"
                Grid.Column="2"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="AutoButton_Click"
                Content="AUTO"
                IsEnabled="False" />


            <Button
                x:Name="Dcs4mAButton"
                Grid.Row="6"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="Dcs4mAButton_Click"
                Content="4mA"
                IsEnabled="False" />
            <Button
                x:Name="Dcs12mAButton"
                Grid.Row="6"
                Grid.Column="1"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="Dcs12mAButton_Click"
                Content="12mA"
                IsEnabled="False" />
            <Button
                x:Name="Dcs20mAButton"
                Grid.Row="6"
                Grid.Column="2"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="Dcs20mAButton_Click"
                Content="20mA"
                IsEnabled="False" />


            <Button
                x:Name="Dcs1VButton"
                Grid.Row="7"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="Dcs1VButton_Click"
                Content="1V"
                IsEnabled="False" />
            <Button
                x:Name="Dcs3VButton"
                Grid.Row="7"
                Grid.Column="1"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="Dcs3VButton_Click"
                Content="3V"
                IsEnabled="False" />
            <Button
                x:Name="Dcs5VButton"
                Grid.Row="7"
                Grid.Column="2"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="Dcs5VButton_Click"
                Content="5V"
                IsEnabled="False" />



            <Common:WaitingCircle
                x:Name="ProgressRing"
                Grid.RowSpan="8"
                Grid.ColumnSpan="3"
                Padding="20,20,20,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed" />

        </Grid>

        <DataGrid
            x:Name="ResultDataGrid"
            Grid.Column="1"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserReorderColumns="False"
            CanUserResizeColumns="False"
            CanUserResizeRows="False"
            CanUserSortColumns="False"
            IsReadOnly="True"
            SelectionUnit="Cell">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="70"
                    Binding="{Binding Dmm1}"
                    CanUserResize="False"
                    Header="DMM1" />
                <DataGridTextColumn
                    Width="70"
                    Binding="{Binding Dmm2}"
                    CanUserResize="False"
                    Header="DMM2" />
                <DataGridTextColumn
                    Width="70"
                    Binding="{Binding Dmm3}"
                    CanUserResize="False"
                    Header="DMM3" />
            </DataGrid.Columns>
            <DataGrid.RowHeaderStyle>
                <Style TargetType="{x:Type DataGridRowHeader}">
                    <Setter Property="Content" Value="{Binding Range}" />
                    <Setter Property="Width" Value="60" />
                </Style>
            </DataGrid.RowHeaderStyle>
        </DataGrid>

    </Grid>
</Window>
