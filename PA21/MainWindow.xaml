<Window
    x:Class="PA21.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PA21"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Grid>


        <DockPanel>
            <StackPanel
                Background="#EEE"
                DockPanel.Dock="Top"
                Orientation="Horizontal">
                <Button
                    Width="100"
                    Margin="5"
                    Click="Page1_Click"
                    Content="検出器" />
                <Button
                    Width="100"
                    Margin="5"
                    Click="Page2_Click"
                    Content="変換器" />
            </StackPanel>

            <!--  ページ表示領域  -->
            <Frame
                x:Name="MainFrame"
                Margin="10"
                NavigationUIVisibility="Hidden" />
        </DockPanel>


    </Grid>
</Window>
