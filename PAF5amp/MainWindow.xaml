<Window
    x:Class="PAF5amp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:Tools.Common.Tool;assembly=Tools.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PAF5amp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PAF5amp"
    Width="220"
    Height="250"
    Icon="/sine.ico"
    ResizeMode="CanMinimize"
    mc:Ignorable="d">

    <Grid x:Name="MainGrid" Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <ComboBox
            x:Name="DcsComboBox"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[DCS]" />
        <ComboBox
            x:Name="DmmComboBox"
            Grid.Column="1"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[DMM]" />
        <ComboBox
            x:Name="OscComboBox"
            Grid.Row="1"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[OSC]" />
        <ComboBox
            x:Name="FgComboBox"
            Grid.Row="1"
            Grid.Column="1"
            Width="80"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[FG]" />

        <Button
            x:Name="ConnectButton"
            Grid.Row="2"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="ConnectButton_Click"
            Content="接続" />
        <Button
            x:Name="ReleaseButton"
            Grid.Row="2"
            Grid.Column="1"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="ReleaseButton_Click"
            Content="解除"
            IsEnabled="False" />

        <CheckBox
            x:Name="HotKeyChekBox"
            Grid.Row="3"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Checked="HotKeyChekBox_Checked"
            Content="HotKey"
            Style="{StaticResource {x:Type ToggleButton}}"
            Unchecked="HotKeyChekBox_Unchecked" />
        <CheckBox
            x:Name="TopMostCheckBox"
            Grid.Row="3"
            Grid.Column="1"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Checked="TopMostCheckBox_Checked"
            Content="最前面"
            Style="{StaticResource {x:Type ToggleButton}}"
            Unchecked="TopMostCheckBox_Unchecked" />

        <Button
            x:Name="InstListButton"
            Grid.Row="5"
            Grid.Column="1"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="InstListButton_Click"
            Content="測定器" />

        <Common:WaitingCircle
            x:Name="ProgressRing"
            Grid.RowSpan="5"
            Grid.ColumnSpan="2"
            Padding="20,20,20,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed" />

    </Grid>
</Window>
