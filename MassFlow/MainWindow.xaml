<Window
    x:Class="MassFlow.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Common="clr-namespace:Tools.Common.Tool;assembly=Tools.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MassFlow"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MassFlow"
    Width="350"
    Height="300"
    Icon="sine.ico"
    ResizeMode="CanMinimize"
    mc:Ignorable="d">

    <Window.Resources>
        <Style x:Key="HiddenIconRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid" Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="0.5*" />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="0.5*" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>


        <ComboBox
            x:Name="DmmComboBox"
            Width="70"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[DMM]" />

        <ComboBox
            x:Name="DcsComboBox"
            Grid.Row="1"
            Width="70"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[DCS]" />

        <ComboBox
            x:Name="OscComboBox"
            Grid.Row="2"
            Width="70"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsEditable="True"
            IsReadOnly="True"
            Text="[OSC]" />

        <Button
            x:Name="DcsOffButton"
            Grid.Row="4"
            Width="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="DcsOffButton_Click"
            Content="OFF" />
        <Button
            x:Name="Dcs2VButton"
            Grid.Row="5"
            Width="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="Dcs2VButton_Click"
            Content="2V" />
        <Button
            x:Name="Dcs8VButton"
            Grid.Row="6"
            Width="40"
            Margin="0,0,0,4"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Click="Dcs8VButton_Click"
            Content="8V" />
        <Button
            x:Name="Dcs1VButton"
            Grid.Row="7"
            Width="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="Dcs1VButton_Click"
            Content="1V" />
        <Button
            x:Name="Dcs7VButton"
            Grid.Row="8"
            Width="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="Dcs7VButton_Click"
            Content="7V" />


        <StackPanel
            Grid.Column="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Label
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="FG数" />
            <ComboBox
                x:Name="FgNumberComboBox"
                Grid.Column="1"
                Width="32"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                SelectedIndex="0"
                SelectionChanged="FgNumberComboBox_SelectionChanged">
                <ComboBoxItem Content="1" />
                <ComboBoxItem Content="2" />
            </ComboBox>
        </StackPanel>
        <Grid
            x:Name="FgNumberGrid1"
            Grid.Row="1"
            Grid.Column="1">
            <ComboBox
                x:Name="Fg01ComboBox"
                Width="70"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[FG]" />
        </Grid>
        <Grid
            x:Name="FgNumberGrid2"
            Grid.Row="1"
            Grid.RowSpan="2"
            Grid.Column="1"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <ComboBox
                x:Name="Fg02_1ComboBox"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[FG1]" />
            <ComboBox
                x:Name="Fg02_2ComboBox"
                Grid.Row="1"
                Width="60"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsEditable="True"
                IsReadOnly="True"
                Text="[FG2]" />
        </Grid>

        <RadioButton
            x:Name="DcsOffRadioButton"
            Grid.Row="4"
            Grid.Column="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Checked="DcsRadioButton_Checked"
            Content="OFF"
            Foreground="Gray"
            GroupName="DcsSettingsGroup"
            IsEnabled="False"
            IsHitTestVisible="False"
            Style="{StaticResource HiddenIconRadioButtonStyle}"
            Unchecked="DcsRadioButton_Unchecked" />
        <RadioButton
            x:Name="Dcs2VRadioButton"
            Grid.Row="5"
            Grid.Column="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Checked="DcsRadioButton_Checked"
            Content="2V"
            Foreground="Gray"
            GroupName="DcsSettingsGroup"
            IsHitTestVisible="False"
            Style="{StaticResource HiddenIconRadioButtonStyle}"
            Unchecked="DcsRadioButton_Unchecked" />
        <RadioButton
            x:Name="Dcs8VRadioButton"
            Grid.Row="6"
            Grid.Column="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Checked="DcsRadioButton_Checked"
            Content="8V"
            Foreground="Gray"
            GroupName="DcsSettingsGroup"
            IsHitTestVisible="False"
            Style="{StaticResource HiddenIconRadioButtonStyle}"
            Unchecked="DcsRadioButton_Unchecked" />
        <RadioButton
            x:Name="Dcs1VRadioButton"
            Grid.Row="7"
            Grid.Column="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Checked="DcsRadioButton_Checked"
            Content="1V"
            Foreground="Gray"
            GroupName="DcsSettingsGroup"
            IsHitTestVisible="False"
            Style="{StaticResource HiddenIconRadioButtonStyle}"
            Unchecked="DcsRadioButton_Unchecked" />
        <RadioButton
            x:Name="Dcs7VRadioButton"
            Grid.Row="8"
            Grid.Column="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Checked="DcsRadioButton_Checked"
            Content="7V"
            Foreground="Gray"
            GroupName="DcsSettingsGroup"
            IsHitTestVisible="False"
            Style="{StaticResource HiddenIconRadioButtonStyle}"
            Unchecked="DcsRadioButton_Unchecked" />


        <Button
            x:Name="ConnectButton"
            Grid.Column="2"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="ConnectButton_Click"
            Content="接続" />

        <CheckBox
            x:Name="HotKeyChekBox"
            Grid.Row="1"
            Grid.Column="2"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Checked="HotKeyChekBox_Checked"
            Content="HotKey"
            Style="{StaticResource {x:Type ToggleButton}}"
            Unchecked="HotKeyChekBox_Unchecked" />

        <Button
            x:Name="FgOscRotationButton"
            Grid.Row="4"
            Grid.RowSpan="5"
            Grid.Column="2"
            Width="40"
            HorizontalAlignment="Center"
            Click="FgOscRotationButton_Click"
            IsEnabled="False">
            <StackPanel>
                <TextBlock HorizontalAlignment="Center" Text="FG" />
                <TextBlock HorizontalAlignment="Center" Text="+" />
                <TextBlock HorizontalAlignment="Center" Text="OSC" />
            </StackPanel>
        </Button>


        <Button
            x:Name="ReleaseButton"
            Grid.Column="3"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="ReleaseButton_Click"
            Content="解除"
            IsEnabled="False" />

        <CheckBox
            x:Name="TopMostCheckBox"
            Grid.Row="1"
            Grid.Column="3"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Checked="TopMostCheckBox_Checked"
            Content="最前面"
            Style="{StaticResource {x:Type ToggleButton}}"
            Unchecked="TopMostCheckBox_Unchecked" />

        <Button
            x:Name="InstListButton"
            Grid.Row="2"
            Grid.Column="3"
            Width="60"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="InstListButton_Click"
            Content="測定器" />

        <RadioButton
            x:Name="FgOscRange0RadioButton"
            Grid.Row="4"
            Grid.Column="3"
            VerticalAlignment="Center"
            Checked="FgOscRadioButton_Checked"
            Content="OFF"
            Foreground="Gray"
            GroupName="FgOscSettingsGroup"
            IsHitTestVisible="False"
            Style="{StaticResource HiddenIconRadioButtonStyle}"
            Unchecked="FgOscRadioButton_Unchecked" />
        <RadioButton
            x:Name="FgOscRange1RadioButton"
            Grid.Row="5"
            Grid.Column="3"
            VerticalAlignment="Center"
            Checked="FgOscRadioButton_Checked"
            Content="小流量"
            Foreground="Gray"
            GroupName="FgOscSettingsGroup"
            IsHitTestVisible="False"
            Style="{StaticResource HiddenIconRadioButtonStyle}"
            Unchecked="FgOscRadioButton_Unchecked" />
        <RadioButton
            x:Name="FgOscRange2RadioButton"
            Grid.Row="6"
            Grid.Column="3"
            VerticalAlignment="Center"
            Checked="FgOscRadioButton_Checked"
            Content="アンプ"
            Foreground="Gray"
            GroupName="FgOscSettingsGroup"
            IsHitTestVisible="False"
            Style="{StaticResource HiddenIconRadioButtonStyle}"
            Unchecked="FgOscRadioButton_Unchecked" />
        <StackPanel
            Grid.Row="7"
            Grid.Column="3"
            Orientation="Horizontal">
            <RadioButton
                x:Name="FgOscRange3RadioButton"
                Grid.Row="7"
                Grid.Column="3"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Checked="FgOscRadioButton_Checked"
                Content="パルス"
                Foreground="Gray"
                GroupName="FgOscSettingsGroup"
                IsHitTestVisible="False"
                Style="{StaticResource HiddenIconRadioButtonStyle}"
                Unchecked="FgOscRadioButton_Unchecked" />
            <RadioButton
                x:Name="FgOscRange4RadioButton"
                Margin="10,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Checked="FgOscRadioButton_Checked"
                Content="L"
                Foreground="Gray"
                GroupName="FgOscSettingsGroup"
                IsHitTestVisible="False"
                Style="{StaticResource HiddenIconRadioButtonStyle}"
                Unchecked="FgOscRadioButton_Unchecked" />
            <RadioButton
                x:Name="FgOscRange5RadioButton"
                Grid.Column="1"
                Margin="10,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Checked="FgOscRadioButton_Checked"
                Content="F"
                Foreground="Gray"
                GroupName="FgOscSettingsGroup"
                IsHitTestVisible="False"
                Style="{StaticResource HiddenIconRadioButtonStyle}"
                Unchecked="FgOscRadioButton_Unchecked" />
        </StackPanel>
        <RadioButton
            x:Name="FgOscRange6RadioButton"
            Grid.Row="8"
            Grid.Column="3"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Checked="FgOscRadioButton_Checked"
            Content="大流量"
            Foreground="Gray"
            GroupName="FgOscSettingsGroup"
            IsHitTestVisible="False"
            Style="{StaticResource HiddenIconRadioButtonStyle}"
            Unchecked="FgOscRadioButton_Unchecked" />


        <StackPanel
            Grid.Row="10"
            Grid.ColumnSpan="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <CheckBox
                x:Name="SerialLockCheckBox"
                Width="20"
                Checked="SerialLockCheckBox_Checked"
                Content="🔒️"
                Style="{StaticResource {x:Type ToggleButton}}"
                Unchecked="SerialLockCheckBox_Unchecked" />
            <TextBox
                x:Name="SerialTextBox"
                Width="80"
                Margin="10,0,0,0"
                MaxLength="8"
                MaxLines="1" />
            <Button
                x:Name="SerialBack"
                Width="20"
                Margin="10,0,0,0"
                Click="SerialBack_Click"
                Content="◀" />
            <Button
                x:Name="SerialNext"
                Width="20"
                Margin="10,0,0,0"
                Click="SerialNext_Click"
                Content="▶" />
        </StackPanel>




        <Common:WaitingCircle
            x:Name="ProgressRing"
            Grid.Row="2"
            Grid.RowSpan="8"
            Grid.ColumnSpan="4"
            Padding="20,20,20,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed" />

    </Grid>
</Window>
